
# Use your machine's local network IP (not localhost) so a physical device can reach your backend
# Find it with: ipconfig (Windows) or ifconfig (Mac/Linux) — look for IPv4 under your Wi-Fi adapter
EXPO_PUBLIC_BACKEND_API_URL=http://192.168.x.x:8000

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # Publishable key only — safe for frontend
